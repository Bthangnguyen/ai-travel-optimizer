APP_ENV=dev
APP_NAME=AI Dynamic Itinerary Optimizer
DEFAULT_CITY=hue
DEFAULT_ORIGIN_NAME=Hue City Center
DEFAULT_ORIGIN_LAT=16.4637
DEFAULT_ORIGIN_LON=107.5909
OSRM_BASE_URL=http://localhost:5000
DATA_PATH=data/sample_pois.json
POI_SOURCE=json
POSTGIS_DSN=postgresql://itinerary:itinerary@localhost:5432/itinerary
REDIS_URL=
STATE_STORE_MODE=hybrid
REROUTE_COOLDOWN_SECONDS=180

# API auth gating
#   internal_key - legacy demo mode, X-API-Key only (safe for LAN/internal)
#   bearer_jwt   - public-safe, Authorization: Bearer <jwt> issued by /auth/token
#   hybrid       - accept either (use during migration)
#   disabled     - open access (development only)
AUTH_MODE=internal_key
JWT_SIGNING_SECRET=
JWT_EXPIRES_IN_SECONDS=3600

# PostGIS spatial prefilter (meters around trip origin); used when POI_SOURCE=postgis
POI_PREFILTER_RADIUS_METERS=50000

# Optional in-process rate limits (per IP). Enable in production or set via Nginx.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_TOKEN_PER_MINUTE=30
RATE_LIMIT_PLAN_PER_MINUTE=60
RATE_LIMIT_REROUTE_PER_MINUTE=60
RATE_LIMIT_TRAFFIC_PER_MINUTE=120
TRAFFIC_CACHE_TTL_SECONDS=60

# Internal demo API protection (used when AUTH_MODE is internal_key or hybrid)
INTERNAL_API_AUTH_ENABLED=true
INTERNAL_API_KEY=demo-internal-key
INTERNAL_API_KEY_HEADER=X-API-Key
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://192.168.1.6:8081,http://192.168.1.6:19006
CORS_ALLOW_CREDENTIALS=false

# LLM runtime configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=12
LLM_MAX_RETRIES=2
LLM_OPENAI_BASE_URL=
LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Provide one of these depending on provider
OPENAI_API_KEY=
GEMINI_API_KEY=
