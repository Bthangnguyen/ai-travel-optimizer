# Production environment template.
# Copy to .env.production on the server (never commit real values).

APP_ENV=production
APP_NAME=AI Dynamic Itinerary Optimizer

DEFAULT_CITY=hue
DEFAULT_ORIGIN_NAME=Hue City Center
DEFAULT_ORIGIN_LAT=16.4637
DEFAULT_ORIGIN_LON=107.5909

# Storage / infrastructure
POI_SOURCE=postgis
STATE_STORE_MODE=redis_required
REROUTE_COOLDOWN_SECONDS=180
REROUTE_DELAY_THRESHOLD_MINUTES=15

# Backing services (values used by docker-compose.prod.yml interpolation)
POSTGRES_DB=itinerary
POSTGRES_USER=itinerary
POSTGRES_PASSWORD=change-me-strong-pass
REDIS_PASSWORD=change-me-strong-pass

# Firebase (optional but required to send FCM reroute push)
FIREBASE_SERVICE_ACCOUNT_PATH=/srv/app/secrets/firebase-service-account.json

# Auth gating
# Options:
#   internal_key  - legacy header X-API-Key (not safe for public builds)
#   bearer_jwt    - Authorization: Bearer <jwt>, tokens issued via POST /auth/token
#   hybrid        - accept either (recommended during migration)
#   disabled      - open access (development only)
AUTH_MODE=bearer_jwt
JWT_SIGNING_SECRET=change-me-long-random-string
JWT_EXPIRES_IN_SECONDS=3600

# Legacy fallback (only used when AUTH_MODE includes internal_key / hybrid)
INTERNAL_API_AUTH_ENABLED=true
INTERNAL_API_KEY=change-me-internal-only
INTERNAL_API_KEY_HEADER=X-API-Key

# Web origins allowed for CORS (comma separated). Keep explicit, no wildcard.
CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOW_CREDENTIALS=false

# LLM runtime configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=12
LLM_MAX_RETRIES=2
LLM_OPENAI_BASE_URL=
LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=
GEMINI_API_KEY=
