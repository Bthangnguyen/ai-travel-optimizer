{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanRequest",
  "type": "object",
  "required": ["prompt"],
  "properties": {
    "prompt": { "type": "string", "minLength": 1 },
    "city": { "type": "string", "default": "hue" },
    "weather": {
      "type": "string",
      "enum": ["clear", "rain"],
      "default": "clear"
    },
    "current_time": {
      "type": ["string", "null"],
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
    },
    "max_candidates": {
      "type": "integer",
      "minimum": 4,
      "maximum": 50,
      "default": 18
    },
    "exclude_poi_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "origin": {
      "type": "object",
      "required": ["lat", "lon"],
      "properties": {
        "name": { "type": "string" },
        "lat": { "type": "number" },
        "lon": { "type": "number" }
      }
    }
  }
}

