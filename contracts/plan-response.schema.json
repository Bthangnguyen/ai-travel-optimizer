{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanResponse",
  "type": "object",
  "required": [
    "trip_id",
    "prompt_snapshot",
    "city",
    "weather",
    "engine_used",
    "fallback_level",
    "constraints",
    "origin",
    "itinerary",
    "discarded_pois",
    "diagnostics"
  ],
  "properties": {
    "trip_id": { "type": "string" },
    "prompt_snapshot": { "type": "string" },
    "city": { "type": "string" },
    "weather": { "type": "string" },
    "engine_used": { "type": "string" },
    "fallback_level": { "type": "integer", "minimum": 0 },
    "constraints": { "type": "object" },
    "origin": { "type": "object" },
    "itinerary": { "type": "array", "items": { "type": "object" } },
    "discarded_pois": { "type": "array", "items": { "type": "object" } },
    "diagnostics": { "type": "object" }
  }
}

