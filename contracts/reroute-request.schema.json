{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RerouteRequest",
  "type": "object",
  "required": ["trip_id", "trigger"],
  "properties": {
    "trip_id": { "type": "string" },
    "prompt": { "type": ["string", "null"] },
    "weather": {
      "type": ["string", "null"],
      "enum": ["clear", "rain", null]
    },
    "current_time": {
      "type": ["string", "null"],
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
    },
    "visited_poi_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "trigger": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["delayed", "rain", "geofence"]
        },
        "minutes_late": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    }
  }
}

