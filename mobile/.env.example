# Mobile runtime environment (loaded by Expo via EXPO_PUBLIC_*).
# Defaults below are safe for LAN/demo use. Public beta builds should use
# EXPO_PUBLIC_AUTH_MODE=bearer_jwt and the HTTPS API domain.

# Base URL of the backend API.
# Dev (LAN):       http://<lan-ip>:8000
# Public beta:     https://api.example.com
EXPO_PUBLIC_API_URL=http://192.168.1.6:8000

# Auth mode used by src/api.ts. Must match backend AUTH_MODE.
#   internal_key - sends X-API-Key header (LAN/demo only)
#   bearer_jwt   - fetches a JWT from /auth/token and sends Authorization header
EXPO_PUBLIC_AUTH_MODE=internal_key

# Only used when EXPO_PUBLIC_AUTH_MODE=internal_key.
# DO NOT commit the real key - leave blank in public builds.
EXPO_PUBLIC_INTERNAL_API_KEY=demo-internal-key
EXPO_PUBLIC_INTERNAL_API_KEY_HEADER=X-API-Key

# Feature flags
EXPO_PUBLIC_ENABLE_GEOFENCE=true
EXPO_PUBLIC_ENABLE_FCM=true
