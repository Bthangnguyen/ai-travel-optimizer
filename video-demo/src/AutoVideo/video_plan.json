      },
      "startFrame": 347,
      "endFrame": 777,
      "duration": 430
    },
    {
      "id": "S4",
      "template": "DarkBeat",
      "text": "And the result?",
      "params": {
        "conceptWord": "KẾT QUẢ?",
        "supportText": "SAU TẤT CẢ",
        "conceptColor": "#F5E500",
        "headType": "wrench",
        "posture": "slouched"
      },
      "startFrame": 777,
      "endFrame": 832,
      "duration": 55
    },
    {
      "id": "S5",
      "template": "DarkBeat",
      "text": "I wasted over a year strictly following useless advice... to the point where I didn't even know what actually worked for me anymore.",
      "params": {
