      "duration": 165
    },
    {
      "id": "S3",
      "template": "DarkBeat",
      "text": "Every day I picked up a new tip from some internet guru. A new book. A new routine. A new system. A new skill. A new \"learn this and your life will change\" promise.",
      "params": {
        "conceptWord": "QUÁ TẢI",
        "supportText": "THÔNG TIN LIÊN TỤC",
        "conceptColor": "#CC0000",
